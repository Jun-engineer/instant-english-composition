{
  "version": "2.0",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "extensions": {
    "http": {
      "cors": {
        "allowedOrigins": [
          "https://speedspeak.jp",
          "capacitor://localhost",
          "ionic://localhost",
          "http://localhost",
          "http://localhost:3000"
        ],
        "allowedMethods": ["GET", "POST", "OPTIONS"],
        "allowedHeaders": ["*"],
        "exposedHeaders": []
      }
    }
  }
}
